# ─── Groq API ───────────────────────────────────────────────
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# ─── Model Settings ─────────────────────────────────────────
# LLM model to use for classification and response generation
MODEL_NAME=llama-3.3-70b-versatile

# ─── Service Settings ───────────────────────────────────────
# Port the AI service runs on
PORT=8000
